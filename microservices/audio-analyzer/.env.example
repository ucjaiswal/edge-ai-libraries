# Audio Analyzer - environment overrides for docker compose.
#
# Copy this file to .env and adjust as needed:
#
#   cp .env.example .env
#
# REGISTRY selects the Docker Hub namespace for the prebuilt image. The
# default `intel` matches the published images on Docker Hub. Override
# only if you push the image to a different namespace.
#
# RELEASE_TAG selects the image tag for both pull and build flows. On
# `docker compose build`, the locally built image is tagged with the
# same `${REGISTRY}/audio-analyzer:${RELEASE_TAG}`, so the pull and
# build paths share one image reference.
#
# The container always runs as UID/GID 1000:1000 (baked into the image).
# Runtime data lives in named Docker volumes initialized with that
# ownership, so no host UID/GID configuration is required.

REGISTRY=intel
RELEASE_TAG=latest
