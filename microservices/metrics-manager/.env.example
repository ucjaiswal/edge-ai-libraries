# =============================================================================
# Metrics Manager - Environment Configuration (reference template)
# =============================================================================
#
# This is a reference template. Copy it to `.env` to start from defaults:
#
#     cp .env.example .env
#
# Every variable below is optional - the defaults work out of the box.
# Uncomment a line only if you need to change the default value.
#
# Variables fall into two groups:
#   * "Container / compose" knobs  - read by `docker compose`         (Docker)
#   * "Application settings"        - read by `app/settings.py`        (Python)
#
# The full reference (with validation rules and types) lives in
# docs/CONFIGURATION.md.
# =============================================================================


# =============================================================================
# Project / image (Docker compose)
# =============================================================================

# Docker Compose project name (becomes the prefix on container/network names).
PROJECT_NAME=metrics-manager

# Docker registry to pull/push from. Empty = local-only image
# (built image is tagged `metrics-manager:<TAG>` without any prefix).
# The official released image is published on Docker Hub as
# `intel/metrics-manager`, so set `REGISTRY=intel/` to reproduce the
# published name locally (must end with a trailing slash).
REGISTRY=

# Image tag - single source of truth is ./VERSION; keep this value in sync,
# or use the Makefile, which reads VERSION automatically (`make build`).
TAG=2026.1.0


# =============================================================================
# Host port mapping (Docker compose)
# =============================================================================
# Internal container ports are fixed (METRICS_PORT, TELEGRAF_PORT below);
# these variables only change which port on the host they map to.

# Metrics Manager REST API + SSE
HOST_METRICS_PORT=9090

# Telegraf Prometheus endpoint (scraped by Prometheus / Grafana / SSE poller)
HOST_TELEGRAF_PORT=9273

# Telegraf HTTP listener (accepts InfluxDB Line Protocol POSTs on /write)
HOST_TELEGRAF_HTTP_PORT=8186


# =============================================================================
# Container runtime (Docker compose)
# =============================================================================

# Run container in privileged mode. Required for full GPU/NPU access on most
# hosts; set to `false` if you only need CPU/RAM/temperature metrics.
PRIVILEGED=true

# Custom Telegraf config files mounted into the container (host paths).
# Override TELEGRAF_CONFIG to ship a completely custom telegraf.conf:
#TELEGRAF_CONFIG=./my-telegraf.conf
# Drop *.conf files into TELEGRAF_CONFIG_DIR to extend the default config:
#TELEGRAF_CONFIG_DIR=./telegraf.d


# =============================================================================
# Service identity (application)
# =============================================================================

# Logical service name reported in /health and structured log records.
#SERVICE_NAME=metrics-manager

# Service version reported in /health. Defaults to the value baked into the
# image at build time (./VERSION). Override only if you need to lie to a
# downstream system about which version is running.
#SERVICE_VERSION=2026.1.0

# Deployment environment. `production` disables the FastAPI /docs and /redoc
# UIs; `development` and `staging` enable them.
#ENVIRONMENT=production

# Override the `host=` tag stamped on every metric (Telegraf, qmassa_reader,
# npu_reader). Empty = use the kernel hostname (default Telegraf behaviour).
# Set to a stable value (e.g. asset tag, k8s node name) to keep Grafana
# dashboards stable across reboots / container restarts.
#METRICS_MANAGER_HOSTNAME=lab-host-42


# =============================================================================
# Network bind (application)
# =============================================================================

# Address the FastAPI server binds to inside the container.
#HOST=0.0.0.0

# Internal API port (the host-side port is HOST_METRICS_PORT above).
METRICS_PORT=9090

# Telegraf Prometheus port the SSE poller scrapes (host-side: HOST_TELEGRAF_PORT).
TELEGRAF_PORT=9273


# =============================================================================
# Logging (application)
# =============================================================================

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output format: `json` for log aggregators (ELK / Loki), `text` for
# human-readable terminal output.
#LOG_FORMAT=json

# Include an ISO-8601 `timestamp` field in every log record.
#LOG_INCLUDE_TIMESTAMP=true


# =============================================================================
# CORS (application)
# =============================================================================

# Allowed origins: `*`, comma-separated list, or JSON array.
# Example (lock down to a dashboard host):
#   CORS_ORIGINS=http://my-dashboard.local:3000,http://localhost:3000
CORS_ORIGINS=*

# Honor the `Origin` header credentials flag. Required for cookies / Auth
# headers in cross-origin requests. Keep `false` unless you know you need it.
#CORS_ALLOW_CREDENTIALS=false


# =============================================================================
# Metrics storage (application)
# =============================================================================

# Directory inside the container where user-provided metric scripts live.
# See docs/CONFIGURATION.md ("Custom Metrics Scripts") for a step-by-step
# walkthrough.
#CUSTOM_METRICS_DIR=/app/custom-metrics

# How long to retain custom metrics in memory before eviction (10 - 86400 s).
METRICS_RETENTION_SECONDS=300

# Maximum metrics per single batch (POST /api/v1/metrics) request (1 - 10000).
MAX_METRICS_BATCH_SIZE=1000

# Max metrics held in memory before the oldest are evicted.
#MAX_METRICS_IN_MEMORY=100000

# Debounce interval for the HTTP push that forwards custom metrics to Telegraf
# on :8186 (0 - 5000 ms). 0 = push synchronously on every write.
#FILE_PERSIST_DEBOUNCE_MS=100


# =============================================================================
# Telegraf integration (application)
# =============================================================================

# Path inside the container to the Telegraf config the app reads for
# diagnostics (the actual Telegraf process is launched by supervisord).
#TELEGRAF_CONFIG_PATH=/etc/telegraf/telegraf.conf

# URL the app POSTs custom metrics to (Telegraf's [[inputs.http_listener_v2]]).
#TELEGRAF_HTTP_ENDPOINT=http://localhost:8186/write


# =============================================================================
# SSE poller (application)
# =============================================================================
# /metrics/stream opens an independent poll loop per connected client.

# Poll interval in milliseconds (100 - 5000). Lower = more frequent SSE
# events, higher CPU per client.
#PROMETHEUS_POLLER_INTERVAL_MS=500

# Telegraf Prometheus endpoint the poller scrapes (usually localhost inside
# the container; override for split deployments).
#PROMETHEUS_TELEGRAF_ENDPOINT=http://localhost:9273


# =============================================================================
# Rate limiting (application)
# =============================================================================
# Exempt paths: /health, /api/v1/stats, SSE endpoints.

#RATE_LIMIT_ENABLED=true
#RATE_LIMIT_REQUESTS_PER_MINUTE=1000
#RATE_LIMIT_BURST=100


# =============================================================================
# Security (application)
# =============================================================================

# Trust X-Forwarded-For / X-Real-IP headers for client identity (rate
# limiting, logging). Enable ONLY when running behind a trusted reverse
# proxy that strips/sets these headers.
#TRUST_FORWARDED_HEADERS=false


# =============================================================================
# Performance (application)
# =============================================================================

# Gzip-compress HTTP responses larger than ~500 bytes.
#ENABLE_GZIP_COMPRESSION=true


# =============================================================================
# Corporate proxy (Docker compose + container)
# =============================================================================
# Set both lower and UPPER case forms - some tools only check one.

#http_proxy=http://proxy.example.com:8080
#HTTP_PROXY=http://proxy.example.com:8080
#https_proxy=http://proxy.example.com:8080
#HTTPS_PROXY=http://proxy.example.com:8080
#no_proxy=localhost,127.0.0.1,.example.com
#NO_PROXY=localhost,127.0.0.1,.example.com
