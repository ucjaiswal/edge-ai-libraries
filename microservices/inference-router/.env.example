# Provider API keys for local dev. Copy this file to `workspace/.env` and fill
# in your secrets. `deployment/docker/docker-compose.yml` forwards these into
# the container, where the config loader resolves ${VAR} references in
# `workspace/config.yaml`.
#
# `workspace/.env` is gitignored; `.env.example` is checked in.

MINIMAX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
