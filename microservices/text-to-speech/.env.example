# Text To Speech - environment overrides for docker compose.
#
# Copy this file to .env and adjust as needed:
#
#   cp .env.example .env
#
# REGISTRY selects the Docker Hub namespace for the prebuilt image. The
# default `intel` matches the published images on Docker Hub.
#
# RELEASE_TAG selects the image tag for both pull and build flows.
#
# RENDER_GID must match the host render node group so the non-root
# container can open /dev/dri/renderD* for GPU access. Determine it with:
#
#   stat -c '%g' /dev/dri/renderD128
#
# The container always runs as UID/GID 1000:1000 (baked into the image).
# Runtime data lives in named Docker volumes initialized with that
# ownership, so no host UID/GID configuration is required.

REGISTRY=intel
RELEASE_TAG=latest
RENDER_GID=992
