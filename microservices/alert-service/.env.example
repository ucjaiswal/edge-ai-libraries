# Alert Service Environment Configuration

# ── Proxy Configuration (optional) ───────────────────────
# Set these if you are behind a corporate proxy
# HTTP_PROXY=http://proxy-pilot.intel.com:912
# HTTPS_PROXY=http://proxy-pilot.intel.com:912

# ── MQTT Mode ────────────────────────────────────────────
# embedded  = Alert service runs its own Mosquitto broker via docker compose
# external  = Uses an external / remote MQTT broker
MQTT_MODE=embedded

# ── MQTT Configuration ───────────────────────────────────
# Embedded mode : MQTT_HOST is ignored (auto-set to compose service "mqtt")
# External mode : MQTT_HOST is the hostname/IP of your external broker
MQTT_HOST=broker.example.com
MQTT_PORT=1883

# External mode only — credentials for the remote broker
# Leave empty when using embedded mode (anonymous access)
MQTT_USERNAME=
MQTT_PASSWORD=

# Service Configuration
TAG=2026.1.0
LOG_LEVEL=INFO
CONFIG_PATH=config/config.yaml

# Delivery Handlers Override (comma-separated: log, mqtt, websocket)
# When set, this overrides the per-subscription delivery list in config.yaml
# Examples:
#   DELIVERY_HANDLERS=log                  → log only
#   DELIVERY_HANDLERS=log,mqtt             → log + MQTT
#   DELIVERY_HANDLERS=log,mqtt,websocket   → all three
# Leave empty to use the config.yaml delivery settings
DELIVERY_HANDLERS=
