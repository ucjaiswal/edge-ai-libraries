# VSS non-secret configuration — development defaults.
#
# This file holds ONLY non-secret config (models, modes, ports, tuning). It is
# safe to commit. Credentials (MinIO/Postgres/RabbitMQ/MQTT) are NEVER stored
# here — per repo policy they must not live in any committed file. They are
# generated at runtime into the gitignored `vss.secrets.env` by
# `scripts/gen-secrets.sh`.
#
# setup.sh reads everything from your shell, so SOURCE both files before deploy:
#     ./.github/skills/vss-up/scripts/gen-secrets.sh        # once: makes vss.secrets.env
#     source .github/skills/vss-up/vss.config.env
#     source .github/skills/vss-up/vss.secrets.env
#     source setup.sh --summary        # or --search / --summary --search / --summary-and-search
#
# Edit values in place. Comment out a line to fall back to whatever is already
# in your shell. The canonical, human-readable source of truth for what each var
# means and which models are supported is docs/user-guide/get-started.md.

# --- Registry / image tag ---
export REGISTRY_URL=intel
export TAG=latest

# --- Summary stack models (required for --summary / --dual / --unified) ---
export VLM_MODEL_NAME="Qwen/Qwen2.5-VL-3B-Instruct"
export VLM_COMPRESSION_WEIGHT_FORMAT=int8
export ENABLED_WHISPER_MODELS="tiny.en,small.en,medium.en"
export OD_MODEL_NAME="yolov8l-worldv2"
# GPU alternative: export VLM_MODEL_NAME="OpenVINO/Phi-3.5-vision-instruct-int8-ov"; export VLM_TARGET_DEVICE=GPU
# If ENABLE_OVMS_LLM_SUMMARY[_GPU]=true: export OVMS_LLM_MODEL_NAME="Intel/neural-chat-7b-v3-3"

# --- Search / embedding stack (required for --search / --dual / --unified) ---
export EMBEDDING_PROCESSING_MODE=sdk            # sdk | api
export MULTIMODAL_EMBEDDING_MODEL="CLIP/clip-vit-b-32"
export VCLIP_MODEL=openai/clip-vit-base-patch32
export SDK_MODEL_ID="CLIP/clip-vit-b-32"
export SDK_USE_OPENVINO=true
# Unified mode searches over summary text (setup.sh validates TEXT_EMBEDDING_MODEL):
export TEXT_EMBEDDING_MODEL="QwenText/qwen3-embedding-0.6b"
export TEXT_EMBEDDING_MODEL_NAME="QwenText/qwen3-embedding-0.6b"

# --- Ingestion / ROI consolidation / telemetry ---
export USB_CAMERA_DEVICE=/dev/video2
export ROI_CONSOLIDATION_ENABLED=true
export ROI_CONSOLIDATION_IOU_THRESHOLD=0.3
export ROI_CONSOLIDATION_CONTEXT_SCALE=0.35
export ENABLE_VSS_COLLECTOR=true

# --- Gated HuggingFace models (uncomment + set token when needed) ---
# A HuggingFace token IS a secret: do not hardcode it here. Export it in your
# shell (export HUGGINGFACE_TOKEN=...) or add it to vss.secrets.env, then:
# export GATED_MODEL=true
