# ==============================================================================
# VSS MCP Server - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the required values before running:
#   cp .env.example .env
#   docker compose up --build
# ==============================================================================

# --- Required: VSS Backend ---------------------------------------------------
# IP or hostname of the VSS backend (used to build URLs and configure no_proxy)
VSS_IP=<VSS_IP>

# IP of the host machine (used to configure allowed origins for MCP Inspector)
HOST_IP=<HOST_IP>

# URL to the VSS OpenAPI/Swagger JSON document
API_SPEC_URL=http://${VSS_IP}:12345/manager/swagger/json

# Base URL of the running VSS REST service
API_BASE_URL=http://${VSS_IP}:12345/manager

# --- MCP Server Settings (optional) ------------------------------------------
# Path to the filter config file inside the container
FILTER_FILE_PATH=/app/search.json

# Bind address and port for the MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Outbound request timeout in seconds
REQUEST_TIMEOUT=60

# Python log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# --- MCP Inspector Settings (optional) ---------------------------------------
# Client UI port (default: 6274)
INSPECTOR_CLIENT_PORT=6274

# Set to "true" to skip Inspector authentication (not recommended for untrusted networks)
DANGEROUSLY_OMIT_AUTH=true

# Alternatively, set a fixed session token for Inspector proxy authentication
# MCP_PROXY_AUTH_TOKEN=

# --- Proxy Settings (optional) ------------------------------------------------
# Set these if you are behind a corporate proxy.
# IMPORTANT: The VSS_IP is automatically added to no_proxy by compose.yaml.
# http_proxy=http://proxy.example.com:port
# https_proxy=http://proxy.example.com:port
# no_proxy=localhost,127.0.0.1
