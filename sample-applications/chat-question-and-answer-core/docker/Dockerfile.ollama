FROM python:3.11-slim AS python-base

ARG UID=1000
ARG GID=1000

# Setting env vars for python and pip
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=off \
    PIP_DISABLE_PIP_VERSION_CHECK=on \
    PIP_DEFAULT_TIMEOUT=100 \
    # Location where packages gets installed
    SETUP_PATH="/opt/projsetup" \
    # Location where virtual env is created
    VENV_PATH="/opt/projsetup/.venv"

# Add venv to path
ENV PATH="$VENV_PATH/bin:$PATH"

# Upgrade pip and setuptools to the latest version to fix vuln
RUN /usr/local/bin/pip install --upgrade --no-cache-dir pip setuptools wheel

# Create a non-root user
RUN groupadd -g ${GID} appuser && \
    useradd -m -s /bin/bash -u ${UID} -g ${GID} appuser && \
    chown -R appuser:appuser $HOME


FROM python-base AS builder-base
RUN apt-get update && apt-get install --no-install-recommends -y curl build-essential zstd

# Install uv from official image
COPY --from=ghcr.io/astral-sh/uv:0.11.21 /uv /usr/local/bin/uv

WORKDIR $SETUP_PATH
COPY pyproject.toml uv.lock ./
RUN uv venv "$VENV_PATH"
ENV UV_PROJECT_ENVIRONMENT="$VENV_PATH"
# Install runtime deps for ollama backend.
RUN uv sync --no-dev --group ollama --no-install-project

# Install ollama and exclude nvidia gpu-related packages
ARG OLLAMA_VERSION=0.30.10
ARG OLLAMA_ARCHIVE=linux-amd64
ARG OLLAMA_URL="https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-${OLLAMA_ARCHIVE}.tar.zst"

RUN mkdir -p /tmp/ollama_lib \
    && curl -fsSL -o /tmp/ollama.tar.zst ${OLLAMA_URL} \
    && tar --zstd -x -f /tmp/ollama.tar.zst -C /tmp/ollama_lib \
    && install -m 0755 /tmp/ollama_lib/bin/ollama /usr/local/bin/ollama \
    && mkdir -p /usr/local/lib/ollama \
    && find /tmp/ollama_lib/lib/ollama -mindepth 1 -maxdepth 1 \
    ! -name cuda_v12 ! -name cuda_v13 ! -name vulkan \
    \( -type f -o -type l \) -exec cp -a {} /usr/local/lib/ollama/ \; \
    && rm -rf /tmp/ollama_lib /tmp/ollama.tar.zst


# `dev` image is used during development / testing
FROM python-base AS dev
ENV FASTAPI_ENV=development

WORKDIR $SETUP_PATH

# Copy uv and the virtual env to current image
COPY --from=builder-base /usr/local/bin/uv /usr/local/bin/uv
COPY --from=builder-base $SETUP_PATH $SETUP_PATH

ENV UV_PROJECT_ENVIRONMENT="$VENV_PATH"

# Install dev/openvino/ollama groups on top of runtime deps.
RUN uv sync --group openvino --group dev --group ollama --no-install-project

# Source code will be mounted here
WORKDIR /app

USER appuser

EXPOSE 8888

CMD ["uvicorn", "app.server:app", "--host", "0.0.0.0", "--port", "8888", "--reload"]


# `prod` image used for runtime
FROM python-base AS prod
ENV FASTAPI_ENV=production

WORKDIR /my-app

RUN apt-get update && apt-get install --no-install-recommends --fix-missing -y \
    libmagic-dev && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Copy the virtual env and dependency metadata
COPY --from=builder-base $SETUP_PATH $SETUP_PATH

# Copy ollama bin and lib
COPY --from=builder-base /usr/local/bin/ollama /usr/local/bin/ollama
COPY --from=builder-base /usr/local/lib/ollama /usr/local/lib/ollama

# Prepare directories for model cache and config
RUN mkdir -p /tmp/model_cache /tmp/model_config

# Copy application code and model config
COPY app ./app
COPY model_config/sample/ollama_template.yaml /tmp/model_config/default_model.yaml

# Set ownership to appuser
RUN chown -R appuser:appuser /my-app /tmp/model_cache /tmp/model_config

USER appuser

EXPOSE 8888

CMD ["uvicorn", "app.server:app", "--host", "0.0.0.0", "--port", "8888"]
